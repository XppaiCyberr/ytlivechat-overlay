<Window x:Class="ytlivechatwedus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="XCYoutube Live Chat Overlay Controller" 
        Icon="logo.png"
        Height="510" Width="440"
        Background="#121214"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Window.Resources>
        <!-- Standard text styling -->
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SubheaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8F90A6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <!-- Gorgeous Gradient Button Style -->
        <Style x:Key="GradientButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" BorderThickness="0" Name="border">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00f2fe" Offset="0"/>
                                    <GradientStop Color="#4facfe" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Panel Border Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A1A1E"/>
            <Setter Property="BorderBrush" Value="#2A2A32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Modern Toggle Switch Style -->
        <Style x:Key="ModernSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#E4E4E6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Background="Transparent" Height="26">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- The Switch Track -->
                            <Border x:Name="Track" Grid.Column="0" Width="38" Height="20" CornerRadius="10" Background="#24242B" BorderBrush="#3E3E4A" BorderThickness="1" VerticalAlignment="Center">
                                <!-- The Switch Thumb -->
                                <Border x:Name="Thumb" Width="14" Height="14" CornerRadius="7" Background="#636681" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2,0,0,0"/>
                            </Border>
                            
                            <!-- Switch Label Text -->
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#00f2fe" Offset="0"/>
                                            <GradientStop Color="#4facfe" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#00f2fe"/>
                                <Setter TargetName="Thumb" Property="Background" Value="White"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Slider Styling -->
        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>

        <!-- SLEEK CUSTOM SCROLLBAR STYLE -->
        <Style TargetType="{x:Type RepeatButton}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="rectangle" 
                                CornerRadius="4" 
                                Background="#2E2E3A" 
                                Opacity="0.8"
                                Margin="1,0,1,0" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="rectangle" Property="Background" Value="#4facfe"/>
                                <Setter TargetName="rectangle" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="rectangle" Property="Background" Value="#00f2fe"/>
                                <Setter TargetName="rectangle" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Margin" Value="2,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true" Background="Transparent">
                            <Border CornerRadius="4" Background="Transparent" />
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title Block -->
            <RowDefinition Height="*"/>    <!-- Settings Main Area (Fit perfectly) -->
            <RowDefinition Height="Auto"/> <!-- Actions Panel -->
        </Grid.RowDefinitions>

        <!-- Title Block -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock FontSize="20" FontWeight="ExtraBold" Foreground="White">
                <Run Text="XC" Foreground="#00f2fe"/>
                <Run Text="Youtube Live Chat Overlay"/>
            </TextBlock>
        </StackPanel>

        <!-- Compact Settings Panel (No ScrollViewer) -->
        <StackPanel Grid.Row="1">
            <!-- 1. Connection Card -->
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="YouTube Live ID / URL:" 
                               Style="{StaticResource SubheaderStyle}" 
                               VerticalAlignment="Center" 
                               Margin="0,0,10,0"/>
                    
                    <TextBox x:Name="txtUrl" Grid.Column="1" Height="28" 
                             Background="#24242B" Foreground="White" 
                             BorderBrush="#3E3E4A" BorderThickness="1" SelectionBrush="#4facfe"
                             Padding="6,2" VerticalContentAlignment="Center" FontSize="12"
                             ToolTip="Enter the 11-char Stream ID or the watch URL."
                             Text="https://www.youtube.com/watch?v=5qap5aO4i9A"/>
                </Grid>
            </Border>

            <!-- 2. Overlay Behavior Card -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Overlay Dimensions &amp; Behavior" Style="{StaticResource HeaderStyle}"/>
                    
                    <!-- Horizontally aligned switches for space efficiency -->
                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <ToggleButton x:Name="chkClickThrough" Grid.Column="0" 
                                      Style="{StaticResource ModernSwitchStyle}" 
                                      Content="Lock Chat (Click-Thru)" IsChecked="False" 
                                      Checked="ChkClickThrough_Changed" Unchecked="ChkClickThrough_Changed"
                                      ToolTip="Locks overlay. Mouse clicks pass straight to games beneath it. (Hotkey: Ctrl+Shift+L)"/>
                        
                        <ToggleButton x:Name="chkAlwaysOnTop" Grid.Column="1" 
                                      Style="{StaticResource ModernSwitchStyle}" 
                                      Content="Always On Top" IsChecked="True" 
                                      Checked="ChkAlwaysOnTop_Changed" Unchecked="ChkAlwaysOnTop_Changed"
                                      ToolTip="Forces the transparent chat layer to float above all active windows."/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 3. Aesthetics & Presets Card -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Aesthetics &amp; Presets" Style="{StaticResource HeaderStyle}"/>

                    <!-- Opacity Slider -->
                    <Grid Margin="0,1,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Overlay Transparency" Style="{StaticResource SubheaderStyle}" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblOpacity" Text="80%" Foreground="#4facfe" FontWeight="Bold" FontSize="11" Grid.Column="1" VerticalAlignment="Center"/>
                    </Grid>
                    <Slider x:Name="sliderOpacity" Minimum="10" Maximum="100" Value="80" IsSnapToTickEnabled="True" TickFrequency="5" ValueChanged="SliderOpacity_ValueChanged"/>

                    <!-- Zoom Slider -->
                    <Grid Margin="0,4,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Chat Font Scaling" Style="{StaticResource SubheaderStyle}" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblZoom" Text="100%" Foreground="#4facfe" FontWeight="Bold" FontSize="11" Grid.Column="1" VerticalAlignment="Center"/>
                    </Grid>
                    <Slider x:Name="sliderZoom" Minimum="50" Maximum="150" Value="100" IsSnapToTickEnabled="True" TickFrequency="5" ValueChanged="SliderZoom_ValueChanged"/>

                    <!-- Style Presets Selection -->
                    <Grid Margin="0,6,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Theme Preset:" Style="{StaticResource SubheaderStyle}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="comboPresets" Grid.Column="1" Height="28" Background="#24242B" Foreground="White" 
                                  BorderBrush="#3E3E4A" BorderThickness="1" Padding="6,2"
                                  VerticalContentAlignment="Center" FontSize="12"
                                  SelectionChanged="ComboPresets_SelectionChanged">
                            <ComboBoxItem Content="Minimalist Bubbles"/>
                            <ComboBoxItem Content="Neon Cyberpunk"/>
                            <ComboBoxItem Content="Clean Monospace"/>
                            <ComboBoxItem Content="Glassmorphic Frost"/>
                            <ComboBoxItem Content="Custom CSS Editor"/>
                        </ComboBox>
                    </Grid>

                    <!-- Compact Custom CSS TextBox -->
                    <TextBox x:Name="txtCustomCss" Height="76" Background="#1D1D22" Foreground="#A3A3B8" 
                             BorderBrush="#3E3E4A" BorderThickness="1" Padding="6" FontFamily="Consolas" 
                             FontSize="11" AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap" Visibility="Collapsed" Margin="0,6,0,0" TextChanged="TxtCustomCss_TextChanged"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Actions Panel -->
        <Border Grid.Row="2" Background="#1A1A1E" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="6" Padding="8,10" Margin="0,5,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="lblStatus" Text="Status: Disconnected" Foreground="#8F90A6" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock x:Name="lblHotkeyReminder" Text="Hotkey: Ctrl+Shift+L to lock/unlock" Foreground="#636681" FontSize="10" Margin="0,1,0,0"/>
                </StackPanel>

                <Button x:Name="btnConnect" Content="LAUNCH OVERLAY" Style="{StaticResource GradientButtonStyle}" Width="130" Grid.Column="1" Click="BtnConnect_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
