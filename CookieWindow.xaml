<Window x:Class="ytlivechatwedus.CookieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Configure YouTube Cookies" 
        Height="485" Width="420"
        Background="#121214"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <!-- Text Styles matching MainWindow -->
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SubheaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8F90A6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="InstructionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A3A3B8"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>

        <!-- Gorgeous Gradient Button Style -->
        <Style x:Key="GradientButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="5" BorderThickness="0" Name="border">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00f2fe" Offset="0"/>
                                    <GradientStop Color="#4facfe" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#24242B"/>
            <Setter Property="Foreground" Value="#A3A3B8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3E3E4A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="5" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" Background="{TemplateBinding Background}" Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E2E38"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A1A20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#321A1A"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#6B2E2E"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="5" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" Background="{TemplateBinding Background}" Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4B2424"/>
                                <Setter Property="Foreground" Value="#FF8787"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#251212"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title & Info -->
            <RowDefinition Height="*"/>    <!-- Text Area -->
            <RowDefinition Height="Auto"/> <!-- Cookie Checker -->
            <RowDefinition Height="Auto"/> <!-- Warning -->
            <RowDefinition Height="Auto"/> <!-- Footer Actions -->
        </Grid.RowDefinitions>

        <!-- Title & Info -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock FontSize="16" FontWeight="ExtraBold" Foreground="White" Margin="0,0,0,4">
                <Run Text="YouTube Live Cookies" Foreground="#00f2fe"/>
            </TextBlock>
            <TextBlock Text="To view member-gated or age-gated chats, you must authorize this session." Style="{StaticResource SubheaderStyle}"/>
            
            <Border Background="#1A1A1E" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,6,0,0">
                <StackPanel>
                    <TextBlock Text="How to extract cookies (including required HttpOnly session tokens):" Style="{StaticResource SubheaderStyle}" Foreground="#E4E4E6" FontSize="11"/>
                    <TextBlock Style="{StaticResource InstructionStyle}">
                        <Run Text="• "/>
                        <Run Text="Method A (Easiest):" FontWeight="Bold" Foreground="#00f2fe"/>
                        <Run Text=" Use a browser extension (e.g. 'Get cookies.txt locally' or 'EditThisCookie') to export cookies for YouTube as JSON or Netscape txt format, then paste the full output."/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource InstructionStyle}">
                        <Run Text="• "/>
                        <Run Text="Method B (No Extensions):" FontWeight="Bold" Foreground="#00f2fe"/>
                        <Run Text=" Open youtube.com → press "/>
                        <Run Text="F12" FontWeight="Bold" Foreground="White"/>
                        <Run Text=" → click the "/>
                        <Run Text="Network" FontWeight="Bold" Foreground="White"/>
                        <Run Text=" tab → refresh (F5) → click 'www.youtube.com' → look under "/>
                        <Run Text="Request Headers" FontWeight="Bold" Foreground="White"/>
                        <Run Text=" → copy the entire value of the "/>
                        <Run Text="Cookie:" FontWeight="Bold" Foreground="White"/>
                        <Run Text=" header."/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Text Area -->
        <TextBox x:Name="txtCookies" Grid.Row="1" Height="120" Background="#1D1D22" Foreground="#A3A3B8" 
                 BorderBrush="#3E3E4A" BorderThickness="1" Padding="8" FontFamily="Consolas" 
                 FontSize="11" AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap" SelectionBrush="#4facfe"
                 ToolTip="Paste raw cookie headers/strings, exported JSON cookies, or Netscape cookies.txt files here."/>

        <!-- Cookie Checker Status -->
        <Border Grid.Row="2" Background="#1A1A1E" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="5" Padding="8" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button x:Name="btnCheckCookies" Grid.Column="0" Content="TEST COOKIES" 
                        Style="{StaticResource SecondaryButtonStyle}" Width="110" Height="26"
                        Click="BtnCheckCookies_Click" VerticalAlignment="Center"/>
                
                <TextBlock x:Name="lblCheckStatus" Grid.Column="1" Text="Status: Not Checked" 
                           Foreground="#8F90A6" FontSize="11" FontWeight="SemiBold" 
                           VerticalAlignment="Center" Margin="10,0,0,0" TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <!-- Warning block -->
        <Border Grid.Row="3" Background="#262115" BorderBrush="#5E4E2A" BorderThickness="1" CornerRadius="5" Padding="6" Margin="0,10,0,10">
            <TextBlock Text="⚠️ WARNING: Cookies contain active login session details. Do not share your cookies or settings.json file with anyone." 
                       Foreground="#FFD43B" FontSize="9.5" FontWeight="SemiBold" TextWrapping="Wrap"/>
        </Border>

        <!-- Footer Actions -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button x:Name="btnClear" Grid.Column="0" Content="CLEAR" Style="{StaticResource DangerButtonStyle}" Width="70" Click="BtnClear_Click"/>
            
            <Button x:Name="btnCancel" Grid.Column="2" Content="CANCEL" Style="{StaticResource SecondaryButtonStyle}" Width="80" Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button x:Name="btnSave" Grid.Column="3" Content="SAVE &amp; APPLY" Style="{StaticResource GradientButtonStyle}" Width="120" Click="BtnSave_Click"/>
        </Grid>
    </Grid>
</Window>
